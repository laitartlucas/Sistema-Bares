
# ── Banco de Dados ──────────────────────────────────────────
POSTGRES_USER=pizzaria
POSTGRES_PASSWORD=pizzaria123
POSTGRES_DB=pizzaria_db
POSTGRES_PORT=5432

# URL completa (usada pelo Prisma)
DATABASE_URL="postgresql://pizzaria:pizzaria123@localhost:5432/pizzaria_db?schema=public"

# ── API ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# JWT — troque por uma string longa e aleatória em produção
JWT_SECRET=troque-por-segredo-longo-e-aleatorio-em-producao
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────
# URLs permitidas (separadas por vírgula)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# ── Cliente / Admin (Vite) ──────────────────────────────────
VITE_API_URL=http://localhost:3001
VITE_WS_URL=http://localhost:3001

# ── Agente de Impressão ──────────────────────────────────────
PRINT_AGENT_SECRET=segredo-compartilhado-com-api
