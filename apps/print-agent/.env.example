# URL da API da pizzaria
API_URL=https://sistema-bares-production.up.railway.app

# Segredo compartilhado entre a API e o agente de impressão
PRINT_SECRET=Lucas@54321

# ── Impressoras ──────────────────────────────────────────────────────────────
# Cada impressora USB deve estar instalada normalmente no Windows e
# COMPARTILHADA (Painel de Controle > Dispositivos e Impressoras >
# botão direito na impressora > Propriedades da impressora > aba
# "Compartilhamento" > marcar "Compartilhar esta impressora" > dar um
# nome simples, sem espaços). Use aqui o mesmo nome do compartilhamento.
#
# Pedidos do tipo COZINHA vão para PRINTER_COZINHA, e os de CAIXA (conta,
# fechamento de caixa) vão para PRINTER_CAIXA.
PRINTER_COZINHA=Teste
PRINTER_CAIXA=BALCAO

# Opcional: impressora usada para relatórios (fechamento de caixa etc.)
# Se não definida, usa a mesma do caixa.
PRINTER_RELATORIO=

# Intervalo de polling de jobs pendentes (ms)
POLL_INTERVAL_MS=5000
