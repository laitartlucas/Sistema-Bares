# URL da API da pizzaria
API_URL=http://localhost:3001

# Segredo compartilhado entre a API e o agente de impressão
PRINT_SECRET=mude-este-segredo-em-producao

# Tipo de conexão com a impressora: usb | network | serial
PRINTER_TYPE=usb

# Para impressora de rede (PRINTER_TYPE=network):
PRINTER_HOST=192.168.1.100
PRINTER_PORT=9100

# Para impressora USB (PRINTER_TYPE=usb) - deixar vazio para auto-detectar
PRINTER_VENDOR_ID=
PRINTER_PRODUCT_ID=

# Interface da impressora (para node-thermal-printer): epson | star | citizen
PRINTER_INTERFACE=usb

# Intervalo de polling de jobs pendentes (ms)
POLL_INTERVAL_MS=5000
